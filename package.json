{
  "name": "vibe-evaluator",
  "version": "1.0.0",
  "description": "GitHub Action that uploads your repository and triggers backend evaluation for results on the Vibe Code Arena website",
  "main": "index.js",
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --target=node24 --outfile=dist/index.js --minify",
    "prepare": "husky",
    "start": "npm run build && node dist/index.js"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=24"
  }
}
